<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1kog0sf" name="DRD" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.48.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <decision id="loan-risk-rules" name="loan-risk-decision">
    <decisionTable id="DecisionTable_0i5oukm" hitPolicy="FIRST">
      <input id="input_credit_score" label="Credit Score">
        <inputExpression id="inputExpression_credit_score" typeRef="integer">
          <text>riskRuleRequest.creditScore</text>
        </inputExpression>
      </input>
      <input id="input_dti_ratio" label="Debt-to-Income Ratio (annual)">
        <inputExpression id="inputExpression_dti" typeRef="double">
          <text>riskRuleRequest.requestedAmount / (riskRuleRequest.monthlyIncome * 12)</text>
        </inputExpression>
      </input>
      <input id="input_age" label="Applicant Age">
        <inputExpression id="inputExpression_age" typeRef="integer">
          <text>riskRuleRequest.applicantAge</text>
        </inputExpression>
      </input>
      <output id="output_risk_level" label="Risk Level" name="riskLevel" typeRef="string" />
      <output id="output_risk_score" label="Risk Score" name="riskScore" typeRef="integer" />
      <rule id="rule_1">
        <description>Excellent credit + very low DTI + age &gt;= ageStandard → LOW</description>
        <inputEntry id="ie_1_cs">
          <text>[riskRuleRequest.riskConfig.csExcellentMin..riskRuleRequest.riskConfig.csExcellentMax]</text>
        </inputEntry>
        <inputEntry id="ie_1_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiVeryLow]</text>
        </inputEntry>
        <inputEntry id="ie_1_age">
          <text>&gt;= riskRuleRequest.riskConfig.ageStandard</text>
        </inputEntry>
        <outputEntry id="oe_1_level">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="oe_1_score">
          <text>10</text>
        </outputEntry>
      </rule>
      <rule id="rule_2">
        <description>Excellent credit + medium DTI → LOW regardless of age</description>
        <inputEntry id="ie_2_cs">
          <text>[riskRuleRequest.riskConfig.csExcellentMin..riskRuleRequest.riskConfig.csExcellentMax]</text>
        </inputEntry>
        <inputEntry id="ie_2_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiMedium]</text>
        </inputEntry>
        <inputEntry id="ie_2_age">
          <text></text>
        </inputEntry>
        <outputEntry id="oe_2_level">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="oe_2_score">
          <text>22</text>
        </outputEntry>
      </rule>
      <rule id="rule_3">
        <description>Very good credit + low DTI + age &gt;= ageStandard → LOW</description>
        <inputEntry id="ie_3_cs">
          <text>[riskRuleRequest.riskConfig.csVeryGoodMin..riskRuleRequest.riskConfig.csVeryGoodMax]</text>
        </inputEntry>
        <inputEntry id="ie_3_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiLow]</text>
        </inputEntry>
        <inputEntry id="ie_3_age">
          <text>&gt;= riskRuleRequest.riskConfig.ageStandard</text>
        </inputEntry>
        <outputEntry id="oe_3_level">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="oe_3_score">
          <text>30</text>
        </outputEntry>
      </rule>
      <rule id="rule_4">
        <description>Good credit + medium DTI + age &gt;= ageMature → MEDIUM</description>
        <inputEntry id="ie_4_cs">
          <text>[riskRuleRequest.riskConfig.csGoodMin..riskRuleRequest.riskConfig.csVeryGoodMax]</text>
        </inputEntry>
        <inputEntry id="ie_4_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiMedium]</text>
        </inputEntry>
        <inputEntry id="ie_4_age">
          <text>&gt;= riskRuleRequest.riskConfig.ageMature</text>
        </inputEntry>
        <outputEntry id="oe_4_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="oe_4_score">
          <text>45</text>
        </outputEntry>
      </rule>
      <rule id="rule_5">
        <description>Acceptable credit + high DTI + age &gt;= ageStandard → MEDIUM</description>
        <inputEntry id="ie_5_cs">
          <text>&gt;= riskRuleRequest.riskConfig.csAcceptableMin</text>
        </inputEntry>
        <inputEntry id="ie_5_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiHigh]</text>
        </inputEntry>
        <inputEntry id="ie_5_age">
          <text>&gt;= riskRuleRequest.riskConfig.ageStandard</text>
        </inputEntry>
        <outputEntry id="oe_5_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="oe_5_score">
          <text>55</text>
        </outputEntry>
      </rule>
      <rule id="rule_6">
        <description>Acceptable credit + high DTI + young applicant → MEDIUM (elevated)</description>
        <inputEntry id="ie_6_cs">
          <text>&gt;= riskRuleRequest.riskConfig.csAcceptableMin</text>
        </inputEntry>
        <inputEntry id="ie_6_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiHigh]</text>
        </inputEntry>
        <inputEntry id="ie_6_age">
          <text>[riskRuleRequest.riskConfig.ageYoungMin..riskRuleRequest.riskConfig.ageYoungMax]</text>
        </inputEntry>
        <outputEntry id="oe_6_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="oe_6_score">
          <text>65</text>
        </outputEntry>
      </rule>
      <rule id="rule_7">
        <description>Fair credit + borderline DTI → MEDIUM (borderline)</description>
        <inputEntry id="ie_7_cs">
          <text>[riskRuleRequest.riskConfig.csFairMin..riskRuleRequest.riskConfig.csFairMax]</text>
        </inputEntry>
        <inputEntry id="ie_7_dti">
          <text>[0..riskRuleRequest.riskConfig.dtiBorderline]</text>
        </inputEntry>
        <inputEntry id="ie_7_age">
          <text></text>
        </inputEntry>
        <outputEntry id="oe_7_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="oe_7_score">
          <text>72</text>
        </outputEntry>
      </rule>
      <rule id="rule_8">
        <description>Poor credit → HIGH</description>
        <inputEntry id="ie_8_cs">
          <text>&lt;= riskRuleRequest.riskConfig.csPoorMax</text>
        </inputEntry>
        <inputEntry id="ie_8_dti">
          <text>&lt;= riskRuleRequest.riskConfig.dtiBorderline</text>
        </inputEntry>
        <inputEntry id="ie_8_age">
          <text></text>
        </inputEntry>
        <outputEntry id="oe_8_level">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="oe_8_score">
          <text>85</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram>
      <dmndi:DMNShape id="Decision_1alzdqg_di" dmnElementRef="loan-risk-rules">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
