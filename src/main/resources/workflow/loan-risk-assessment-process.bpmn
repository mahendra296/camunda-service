  "dtiHigh":        0.50,
  "ageStandard":    25,
  "ageMature":      30,
  "ageYoungMin":    18,
  "ageYoungMax":    24
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="assoc_riskConfigDb_schema" sourceRef="DataStoreReference_riskConfigDb" targetRef="TextAnnotation_riskConfigDbSchema" />
    <bpmn:association id="assoc_riskConfig_schema" sourceRef="DataObjectReference_riskConfig" targetRef="TextAnnotation_riskConfigSchema" />
  </bpmn:process>
