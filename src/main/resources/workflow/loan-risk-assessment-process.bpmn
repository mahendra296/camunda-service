<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_LoanRiskAssessment" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.48.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.6.0">
  <bpmn:itemDefinition id="ItemDefinition_riskConfig" itemKind="Information" structureRef="com.camunda.model.RiskConfig" />
  <bpmn:process id="loan-risk-assessment-process" name="Loan Risk Assessment" isExecutable="true">
    <bpmn:dataStoreReference id="DataStoreReference_riskConfigDb" name="risk_config&#10;[PostgreSQL]" />
    <bpmn:dataObject id="DataObject_riskConfig" name="riskConfig" itemSubjectRef="ItemDefinition_riskConfig" />
    <bpmn:dataObjectReference id="DataObjectReference_riskConfig" name="riskConfig&#10;{object}" dataObjectRef="DataObject_riskConfig" />
    <bpmn:startEvent id="start_event_application_received" name="Application&#10;Received">
      <bpmn:outgoing>flow_start_to_validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_validate_application" name="Validate&#10;Application">
      <bpmn:documentation>Validates the loan application fields and loads dynamic risk thresholds from the
risk_config database table.

Single output variable: validateApplicationResponse (com.camunda.dto.ValidateApplicationResponse)
{
  "applicationValid": true,
  "validationError":  null,
  "validatedAt":      1719820800000,
  "riskConfig": {
    "csExcellentMin": 750,  "csExcellentMax": 850,
    "csVeryGoodMin":  700,  "csVeryGoodMax":  749,
    "csGoodMin":      650,  "csAcceptableMin": 600,
    "csFairMin":      500,  "csFairMax":       599,
    "csPoorMax":      500,
    "dtiVeryLow":    0.25,  "dtiLow":         0.30,
    "dtiBorderline": 0.35,  "dtiMedium":      0.40,
    "dtiHigh":       0.50,
    "ageStandard":     25,  "ageMature":        30,
    "ageYoungMin":     18,  "ageYoungMax":      24
  }
}

Gateway reads: validateApplicationResponse.applicationValid
DMN reads:     validateApplicationResponse.riskConfig</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan.validate-application" retries="3" />
        <zeebe:ioMapping>
          <zeebe:output source="=validateApplicationResponse" target="validateApplicationResponse" />
        </zeebe:ioMapping>
        <zeebe:properties>
          <zeebe:property name="riskConfig.csExcellentMin" value="int -- lower bound for Excellent credit score band (default 750)" />
          <zeebe:property name="riskConfig.csExcellentMax" value="int -- upper bound for Excellent credit score band (default 850)" />
          <zeebe:property name="riskConfig.csVeryGoodMin" value="int -- lower bound for Very Good band (default 700)" />
          <zeebe:property name="riskConfig.csVeryGoodMax" value="int -- upper bound for Very Good band (default 749)" />
          <zeebe:property name="riskConfig.csGoodMin" value="int -- lower bound for Good band (default 650)" />
          <zeebe:property name="riskConfig.csAcceptableMin" value="int -- lower bound for Acceptable band (default 600)" />
          <zeebe:property name="riskConfig.csFairMin" value="int -- lower bound for Fair band (default 500)" />
          <zeebe:property name="riskConfig.csFairMax" value="int -- upper bound for Fair band (default 599)" />
          <zeebe:property name="riskConfig.csPoorMax" value="int -- score threshold for Poor risk / rule 8 (default 500)" />
          <zeebe:property name="riskConfig.dtiVeryLow" value="double -- very-low DTI upper bound (default 0.25)" />
          <zeebe:property name="riskConfig.dtiLow" value="double -- low DTI upper bound (default 0.30)" />
          <zeebe:property name="riskConfig.dtiBorderline" value="double -- borderline DTI upper bound (default 0.35)" />
          <zeebe:property name="riskConfig.dtiMedium" value="double -- medium DTI upper bound (default 0.40)" />
          <zeebe:property name="riskConfig.dtiHigh" value="double -- high DTI upper bound (default 0.50)" />
          <zeebe:property name="riskConfig.ageStandard" value="int -- standard minimum applicant age (default 25)" />
          <zeebe:property name="riskConfig.ageMature" value="int -- mature minimum applicant age (default 30)" />
          <zeebe:property name="riskConfig.ageYoungMin" value="int -- young band lower bound (default 18)" />
          <zeebe:property name="riskConfig.ageYoungMax" value="int -- young band upper bound (default 24)" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_to_validate</bpmn:incoming>
      <bpmn:outgoing>flow_validate_to_gw_valid</bpmn:outgoing>
      <bpmn:property id="Property_0wxmboo" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="dia_from_risk_config_db">
        <bpmn:sourceRef>DataStoreReference_riskConfigDb</bpmn:sourceRef>
        <bpmn:targetRef>Property_0wxmboo</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="doa_to_risk_config_obj">
        <bpmn:targetRef>DataObjectReference_riskConfig</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_application_valid" name="Application&#10;Valid?">
      <bpmn:incoming>flow_validate_to_gw_valid</bpmn:incoming>
      <bpmn:outgoing>flow_gw_valid_to_evaluate</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_valid_to_rejection</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_send_rejection_notification" name="Send Rejection&#10;Notification">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan.send-rejection-notification" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_valid_to_rejection</bpmn:incoming>
      <bpmn:outgoing>flow_rejection_to_end_invalid</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="task_evaluate_risk_rules" name="Evaluate Risk&#10;Rules">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="loan-risk-rules" resultVariable="riskDecision" />
        <zeebe:ioMapping>
          <zeebe:input source="=validateApplicationResponse" target="riskRuleRequest" />
          <zeebe:output source="=riskDecision" target="riskDecision" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_valid_to_evaluate</bpmn:incoming>
      <bpmn:outgoing>flow_evaluate_to_gw_risk</bpmn:outgoing>
      <bpmn:property id="Property_18x6c5a" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="dia_from_risk_config_obj">
        <bpmn:sourceRef>DataObjectReference_riskConfig</bpmn:sourceRef>
        <bpmn:targetRef>Property_18x6c5a</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:businessRuleTask>
    <bpmn:exclusiveGateway id="gw_risk_level" name="Risk&#10;Level?">
      <bpmn:incoming>flow_evaluate_to_gw_risk</bpmn:incoming>
      <bpmn:outgoing>flow_gw_risk_to_approve</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_risk_to_review</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_risk_to_reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_auto_approve_loan" name="Auto Approve&#10;Loan">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan.auto-approve" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_risk_to_approve</bpmn:incoming>
      <bpmn:outgoing>flow_approve_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_manual_review_loan" name="Manual Loan&#10;Review">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_risk_to_review</bpmn:incoming>
      <bpmn:outgoing>flow_review_to_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="task_auto_reject_loan" name="Auto Reject&#10;Loan">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="loan.auto-reject" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_risk_to_reject</bpmn:incoming>
      <bpmn:outgoing>flow_reject_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_application_invalid" name="Application&#10;Invalid">
      <bpmn:incoming>flow_rejection_to_end_invalid</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_loan_approved" name="Loan&#10;Approved">
      <bpmn:incoming>flow_approve_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_review_pending" name="Review&#10;Pending">
      <bpmn:incoming>flow_review_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_loan_rejected" name="Loan&#10;Rejected">
      <bpmn:incoming>flow_reject_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_validate" sourceRef="start_event_application_received" targetRef="task_validate_application" />
    <bpmn:sequenceFlow id="flow_validate_to_gw_valid" sourceRef="task_validate_application" targetRef="gw_application_valid" />
    <bpmn:sequenceFlow id="flow_gw_valid_to_evaluate" name="Valid" sourceRef="gw_application_valid" targetRef="task_evaluate_risk_rules">
      <bpmn:conditionExpression>=validateApplicationResponse.applicationValid = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_valid_to_rejection" name="Invalid" sourceRef="gw_application_valid" targetRef="task_send_rejection_notification">
      <bpmn:conditionExpression>=validateApplicationResponse.applicationValid = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_rejection_to_end_invalid" sourceRef="task_send_rejection_notification" targetRef="end_application_invalid" />
    <bpmn:sequenceFlow id="flow_evaluate_to_gw_risk" sourceRef="task_evaluate_risk_rules" targetRef="gw_risk_level" />
    <bpmn:sequenceFlow id="flow_gw_risk_to_approve" name="LOW" sourceRef="gw_risk_level" targetRef="task_auto_approve_loan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision.riskLevel = "LOW"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_risk_to_review" name="MEDIUM" sourceRef="gw_risk_level" targetRef="task_manual_review_loan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision.riskLevel = "MEDIUM"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_risk_to_reject" name="HIGH" sourceRef="gw_risk_level" targetRef="task_auto_reject_loan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=riskDecision.riskLevel = "HIGH"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_approve_to_end" sourceRef="task_auto_approve_loan" targetRef="end_loan_approved" />
    <bpmn:sequenceFlow id="flow_review_to_end" sourceRef="task_manual_review_loan" targetRef="end_review_pending" />
    <bpmn:sequenceFlow id="flow_reject_to_end" sourceRef="task_auto_reject_loan" targetRef="end_loan_rejected" />
    <bpmn:textAnnotation id="TextAnnotation_riskConfigDbSchema">
      <bpmn:text>risk_config  (PostgreSQL)
config_key   : VARCHAR(100)  PK
config_value : NUMERIC(10,4) NOT NULL
description  : VARCHAR(255)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_riskConfigSchema">
      <bpmn:text>// riskConfig — process variable (com.camunda.model.RiskConfig)
{
  "csExcellentMin": 750,
