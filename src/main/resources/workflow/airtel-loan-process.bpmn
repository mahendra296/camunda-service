<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_AirtelLoan" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.6.0">
  <bpmn:message id="Message_LoanRequest" name="LoanRequest" />
  <bpmn:message id="Message_KycResponse" name="KycResponse">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_LoanApplication" name="LoanApplication">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_KycRequest" name="KycRequest">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_OptedInNotification" name="OptedInNotification">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_EligibilityResult" name="EligibilityResult">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_SubmissionConfirmation" name="SubmissionConfirmation">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_LoanApproved" name="LoanApproved">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=msisdn" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:collaboration id="Collaboration_AirtelLoan" name="Airtel Loan Collaboration">
    <bpmn:participant id="Participant_Airtel" name="Airtel" processRef="Process_Airtel" />
    <bpmn:participant id="Participant_CapBPM" name="CAPBPM" processRef="airtel-loan-capbpm-process" />
    <bpmn:participant id="Participant_GNU" name="GnuCreditScore" processRef="Process_GNU" />
    <bpmn:participant id="Participant_CBS" name="CBS (Core Banking)" processRef="Process_CBS" />
    <bpmn:messageFlow id="mf_loan_request" name="Loan Request" sourceRef="airtel_send_loan_req" targetRef="capbpm_start" />
    <bpmn:messageFlow id="mf_kyc_request" name="KYC Request" sourceRef="task_fetch_kyc" targetRef="airtel_recv_kyc_request" />
    <bpmn:messageFlow id="mf_kyc_response" name="KYC Response" sourceRef="airtel_send_kyc_response" targetRef="catch_kyc_response" />
    <bpmn:messageFlow id="mf_optedin" name="Opted-In Notification" sourceRef="task_notify_optedin" targetRef="airtel_recv_optedin" />
    <bpmn:messageFlow id="mf_credit_request" name="Credit Score Request" sourceRef="task_get_credit_score" targetRef="gnu_start" />
    <bpmn:messageFlow id="mf_credit_response" name="Credit Score Response" sourceRef="gnu_end" targetRef="task_get_credit_score" />
    <bpmn:messageFlow id="mf_eligibility" name="Eligibility Result" sourceRef="task_send_eligibility" targetRef="airtel_recv_eligibility" />
    <bpmn:messageFlow id="mf_loan_application" name="Loan Application" sourceRef="airtel_send_loan_app" targetRef="catch_loan_application" />
    <bpmn:messageFlow id="mf_submission_conf" name="Submission Confirmation" sourceRef="task_send_submission_conf" targetRef="airtel_recv_submission_conf" />
    <bpmn:messageFlow id="mf_cbs_check" name="Check Customer" sourceRef="task_check_cbs" targetRef="cbs_start" />
    <bpmn:messageFlow id="mf_cbs_response" name="Customer Info Response" sourceRef="cbs_task_check" targetRef="task_check_cbs" />
    <bpmn:messageFlow id="mf_cbs_onboard" name="Onboard Request" sourceRef="task_onboard_cbs" targetRef="cbs_task_onboard" />
    <bpmn:messageFlow id="mf_cbs_disburse" name="Disbursement Request" sourceRef="task_process_disbursement" targetRef="cbs_task_disburse" />
    <bpmn:messageFlow id="mf_loan_approved" name="Loan Approved" sourceRef="task_notify_approved" targetRef="airtel_recv_approval" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Airtel" name="Airtel" isExecutable="true">
    <bpmn:endEvent id="airtel_end_approved" name="Loan Approved">
      <bpmn:incoming>af9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="airtel_recv_approval" name="Receive Loan&#10;Approval">
      <bpmn:incoming>af8</bpmn:incoming>
      <bpmn:outgoing>af9</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_recv_approval" messageRef="Message_LoanApproved" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="airtel_recv_submission_conf" name="Receive Submission&#10;Confirmation">
      <bpmn:incoming>af7</bpmn:incoming>
      <bpmn:outgoing>af8</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_recv_submission_conf" messageRef="Message_SubmissionConfirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="airtel_send_loan_app" name="Submit Loan&#10;Application">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="airtel.sendLoanApplication" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>af6_yes</bpmn:incoming>
      <bpmn:outgoing>af7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="af6_no" name="Not Eligible" sourceRef="airtel_gw_eligible" targetRef="airtel_end_not_eligible">
      <bpmn:conditionExpression>=eligible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="af3c" sourceRef="airtel_task_provide_kyc" targetRef="airtel_send_kyc_response" />
    <bpmn:sequenceFlow id="af3d" sourceRef="airtel_send_kyc_response" targetRef="airtel_recv_optedin" />
    <bpmn:sequenceFlow id="af3b" sourceRef="airtel_recv_kyc_request" targetRef="airtel_task_provide_kyc" />
    <bpmn:sequenceFlow id="af3a" sourceRef="airtel_send_loan_req" targetRef="airtel_recv_kyc_request" />
    <bpmn:sequenceFlow id="af2" sourceRef="airtel_task_select" targetRef="airtel_send_loan_req" />
    <bpmn:sequenceFlow id="af1" sourceRef="airtel_start" targetRef="airtel_task_select" />
    <bpmn:sequenceFlow id="af4" sourceRef="airtel_recv_optedin" targetRef="airtel_recv_eligibility" />
    <bpmn:sequenceFlow id="af5" sourceRef="airtel_recv_eligibility" targetRef="airtel_gw_eligible" />
    <bpmn:sequenceFlow id="af6_yes" name="Eligible" sourceRef="airtel_gw_eligible" targetRef="airtel_send_loan_app">
      <bpmn:conditionExpression>=eligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="af9" sourceRef="airtel_recv_approval" targetRef="airtel_end_approved" />
    <bpmn:sequenceFlow id="af8" sourceRef="airtel_recv_submission_conf" targetRef="airtel_recv_approval" />
    <bpmn:sequenceFlow id="af7" sourceRef="airtel_send_loan_app" targetRef="airtel_recv_submission_conf" />
    <bpmn:exclusiveGateway id="airtel_gw_eligible" name="Eligible?">
      <bpmn:incoming>af5</bpmn:incoming>
      <bpmn:outgoing>af6_yes</bpmn:outgoing>
      <bpmn:outgoing>af6_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="airtel_recv_eligibility" name="Receive&#10;Eligibility Result">
      <bpmn:incoming>af4</bpmn:incoming>
      <bpmn:outgoing>af5</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_recv_eligibility" messageRef="Message_EligibilityResult" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="airtel_recv_optedin" name="Opted-In&#10;Confirmed">
      <bpmn:incoming>af3d</bpmn:incoming>
      <bpmn:outgoing>af4</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_recv_optedin" messageRef="Message_OptedInNotification" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="airtel_send_kyc_response" name="Send KYC&#10;Response">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="airtel.sendKycResponse" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>af3c</bpmn:incoming>
      <bpmn:outgoing>af3d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="airtel_task_provide_kyc" name="Provide KYC&#10;Data">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="airtel.provideKycData" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>af3b</bpmn:incoming>
      <bpmn:outgoing>af3c</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="airtel_recv_kyc_request" name="Receive KYC&#10;Request">
      <bpmn:incoming>af3a</bpmn:incoming>
      <bpmn:outgoing>af3b</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_recv_kyc_req" messageRef="Message_KycRequest" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="airtel_send_loan_req" name="Send Loan&#10;Request">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="airtel.sendLoanRequest" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>af2</bpmn:incoming>
      <bpmn:outgoing>af3a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="airtel_task_select" name="Select Apply&#10;Loan Option">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="airtel.selectLoanOption" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>af1</bpmn:incoming>
      <bpmn:outgoing>af2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:startEvent id="airtel_start" name="Customer Dials&#10;*123#">
      <bpmn:outgoing>af1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="airtel_end_not_eligible" name="Not Eligible">
      <bpmn:incoming>af6_no</bpmn:incoming>
    </bpmn:endEvent>
  </bpmn:process>
  <bpmn:process id="airtel-loan-capbpm-process" name="CAPBPM — Airtel Loan Orchestration" isExecutable="true">
    <bpmn:startEvent id="capbpm_start" name="Receive Loan&#10;Request from Airtel">
      <bpmn:outgoing>cf1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_capbpm_start" messageRef="Message_LoanRequest" />
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_check_customer" name="Check Customer&#10;Exists in CapBPM">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.checkCustomerExists" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf1</bpmn:incoming>
      <bpmn:outgoing>cf2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_customer_exists" name="Customer&#10;Exists?">
      <bpmn:incoming>cf2</bpmn:incoming>
      <bpmn:outgoing>cf3_yes</bpmn:outgoing>
      <bpmn:outgoing>cf3_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_fetch_kyc" name="Fetch KYC&#10;from Airtel">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.fetchKycFromAirtel" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf3_no</bpmn:incoming>
      <bpmn:outgoing>cf4a</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_merge_optin">
      <bpmn:incoming>cf6</bpmn:incoming>
      <bpmn:incoming>cf3_yes</bpmn:incoming>
      <bpmn:outgoing>cf7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_optedin" name="Notify Airtel&#10;Customer Opted-In">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.notifyOptedIn" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf7</bpmn:incoming>
      <bpmn:outgoing>cf8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_optin_customer" name="Opt-In Customer&#10;in CapBPM">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.optInCustomer" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf5</bpmn:incoming>
      <bpmn:outgoing>cf6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_store_kyc" name="Store KYC&#10;Data">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.storeKycData" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf4b</bpmn:incoming>
      <bpmn:outgoing>cf5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="catch_kyc_response" name="Receive KYC&#10;Response">
      <bpmn:incoming>cf4a</bpmn:incoming>
      <bpmn:outgoing>cf4b</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_catch_kyc" messageRef="Message_KycResponse" />
    </bpmn:intermediateCatchEvent>
    <bpmn:callActivity id="task_get_credit_score" name="Get Credit Score&#10;(GnuCreditScore)">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_GNU" propagateAllChildVariables="true" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf8</bpmn:incoming>
      <bpmn:outgoing>cf9</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="task_send_eligibility" name="Send Eligibility&#10;Result to Airtel">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.sendEligibilityResult" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf9</bpmn:incoming>
      <bpmn:outgoing>cf10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_notify_approved" name="Notify Airtel&#10;Loan Approved">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.notifyLoanApproved" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf18</bpmn:incoming>
      <bpmn:outgoing>cf19</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="capbpm_end" name="Loan Disbursed&#10;&#38; Airtel Notified">
      <bpmn:incoming>cf19</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:callActivity id="task_check_cbs" name="CBS&#10;(Core Banking)">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="Process_CBS" propagateAllChildVariables="true" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf13</bpmn:incoming>
      <bpmn:outgoing>cf18</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:serviceTask id="task_send_submission_conf" name="Send Submission&#10;Confirmation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.sendSubmissionConfirmation" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf12</bpmn:incoming>
      <bpmn:outgoing>cf13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_store_loan" name="Store Loan&#10;Information">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="capbpm.storeLoanInfo" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>cf11_yes</bpmn:incoming>
      <bpmn:outgoing>cf12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="catch_loan_application" name="Receive Loan&#10;Application">
      <bpmn:incoming>cf11_yes</bpmn:incoming>
      <bpmn:outgoing>cf11b</bpmn:outgoing>
      <bpmn:messageEventDefinition id="med_catch_loan_app" messageRef="Message_LoanApplication" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="gw_eligible" name="Customer&#10;Eligible?">
      <bpmn:incoming>cf10</bpmn:incoming>
      <bpmn:outgoing>cf11_yes</bpmn:outgoing>
      <bpmn:outgoing>cf11_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_not_eligible" name="Loan Not&#10;Eligible">
      <bpmn:incoming>cf11_no</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="cf1" sourceRef="capbpm_start" targetRef="task_check_customer" />
    <bpmn:sequenceFlow id="cf2" sourceRef="task_check_customer" targetRef="gw_customer_exists" />
    <bpmn:sequenceFlow id="cf3_yes" name="Existing Customer" sourceRef="gw_customer_exists" targetRef="gw_merge_optin">
      <bpmn:conditionExpression>=customerExists = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="cf3_no" name="New Customer" sourceRef="gw_customer_exists" targetRef="task_fetch_kyc">
      <bpmn:conditionExpression>=customerExists = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="cf4a" sourceRef="task_fetch_kyc" targetRef="catch_kyc_response" />
    <bpmn:sequenceFlow id="cf6" sourceRef="task_optin_customer" targetRef="gw_merge_optin" />
    <bpmn:sequenceFlow id="cf7" sourceRef="gw_merge_optin" targetRef="task_notify_optedin" />
    <bpmn:sequenceFlow id="cf8" sourceRef="task_notify_optedin" targetRef="task_get_credit_score" />
    <bpmn:sequenceFlow id="cf5" sourceRef="task_store_kyc" targetRef="task_optin_customer" />
    <bpmn:sequenceFlow id="cf4b" sourceRef="catch_kyc_response" targetRef="task_store_kyc" />
    <bpmn:sequenceFlow id="cf9" sourceRef="task_get_credit_score" targetRef="task_send_eligibility" />
    <bpmn:sequenceFlow id="cf10" sourceRef="task_send_eligibility" targetRef="gw_eligible" />
    <bpmn:sequenceFlow id="cf18" sourceRef="task_check_cbs" targetRef="task_notify_approved" />
    <bpmn:sequenceFlow id="cf19" sourceRef="task_notify_approved" targetRef="capbpm_end" />
    <bpmn:sequenceFlow id="cf13" sourceRef="task_send_submission_conf" targetRef="task_check_cbs" />
    <bpmn:sequenceFlow id="cf12" sourceRef="task_store_loan" targetRef="task_send_submission_conf" />
    <bpmn:sequenceFlow id="cf11b" sourceRef="catch_loan_application" targetRef="task_store_loan" />
    <bpmn:sequenceFlow id="cf11_yes" name="Eligible" sourceRef="gw_eligible" targetRef="catch_loan_application">
      <bpmn:conditionExpression>=eligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="cf11_no" name="Not Eligible" sourceRef="gw_eligible" targetRef="end_not_eligible">
      <bpmn:conditionExpression>=eligible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
  </bpmn:process>
  <bpmn:process id="Process_GNU" name="GnuCreditScore" isExecutable="true">
    <bpmn:startEvent id="gnu_start" name="Start Credit&#10;Score">
      <bpmn:outgoing>gf1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="gnu_task_calculate" name="Calculate&#10;Credit Score">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="gnu.getCreditScore" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>gf1</bpmn:incoming>
      <bpmn:outgoing>gf2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="gnu_end" name="Return Credit&#10;Score Response">
      <bpmn:incoming>gf2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="gf1" sourceRef="gnu_start" targetRef="gnu_task_calculate" />
    <bpmn:sequenceFlow id="gf2" sourceRef="gnu_task_calculate" targetRef="gnu_end" />
  </bpmn:process>
  <bpmn:process id="Process_CBS" name="CBS (Core Banking)" isExecutable="true">
    <bpmn:startEvent id="cbs_start" name="Start CBS&#10;Processing">
      <bpmn:outgoing>bf1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="cbs_end" name="Disbursement&#10;Complete">
      <bpmn:incoming>bf6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="cbs_task_disburse" name="Process Loan&#10;Disbursement">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="cbs.processLoanDisbursement" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>bf5</bpmn:incoming>
      <bpmn:outgoing>bf6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="cbs_gw_merge">
      <bpmn:incoming>bf4</bpmn:incoming>
      <bpmn:incoming>bf3_yes</bpmn:incoming>
      <bpmn:outgoing>bf5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="cbs_task_onboard" name="Onboard New&#10;Customer">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="cbs.onboardCustomer" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>bf3_no</bpmn:incoming>
      <bpmn:outgoing>bf4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="cbs_gw_exists" name="Customer&#10;Exists?">
      <bpmn:incoming>bf2</bpmn:incoming>
      <bpmn:outgoing>bf3_no</bpmn:outgoing>
      <bpmn:outgoing>bf3_yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="cbs_task_check" name="Check Customer&#10;Profile">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="cbs.checkCustomer" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>bf1</bpmn:incoming>
      <bpmn:outgoing>bf2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="bf1" sourceRef="cbs_start" targetRef="cbs_task_check" />
    <bpmn:sequenceFlow id="bf6" sourceRef="cbs_task_disburse" targetRef="cbs_end" />
