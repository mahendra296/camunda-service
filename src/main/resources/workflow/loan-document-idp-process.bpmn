      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start_to_gw_split_di" bpmnElement="flow_start_to_gw_split">
        <di:waypoint x="198" y="380" />
        <di:waypoint x="310" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_gw_split_to_store_structured_di" bpmnElement="flow_gw_split_to_store_structured">
        <di:waypoint x="335" y="355" />
