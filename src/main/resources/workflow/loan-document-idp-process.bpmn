<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_LoanDocumentIdp" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="c72e043" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="loan-document-idp-process" name="Loan Document IDP" isExecutable="true">
    <bpmn:startEvent id="start_event_document_uploaded" name="Document&#10;Uploaded">
      <bpmn:outgoing>flow_start_to_gw_split</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_store_structured" name="Store&#10;Structured Doc">
      <bpmn:documentation>Uploads the file at structuredDocumentPath into Camunda's Document Store via
StoreLoanDocumentWorker (idp.store-document) — the same worker reused by all 3 branches.
Output is renamed via zeebe:output so it doesn't collide with the other two parallel
branches writing into the same process instance scope: structuredLoanDocument,
structuredDocumentStoredAt.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.store-document" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=documentPath" target="documentPath" />
          <zeebe:output source="=document" target="structuredLoanDocument" />
          <zeebe:output source="=documentStoredAt" target="structuredDocumentStoredAt" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_split_to_store_structured</bpmn:incoming>
      <bpmn:outgoing>flow_store_structured_to_extract_structured</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_print_structured" name="Print&#10;Structured Result">
      <bpmn:documentation>Logs idpExtractionResultStructured + extractedDataResponseStructured via
PrintExtractionResultWorker (idp.print-extraction-result — one job type shared by all 3
print nodes, disambiguated by templateLabel).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.print-extraction-result" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Structured PDF Extract&#34;" target="templateLabel" />
          <zeebe:input source="=idpExtractionResultStructured" target="extractionResult" />
          <zeebe:input source="=extractedDataResponseStructured" target="extractedData" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0lrpjgc</bpmn:incoming>
      <bpmn:outgoing>flow_print_structured_to_gw_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_store_unstructured" name="Store&#10;Unstructured Doc">
      <bpmn:documentation>Uploads the file at unstructuredDocumentPath into Camunda's Document Store.
Output renamed to unstructuredLoanDocument / unstructuredDocumentStoredAt.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.store-document" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=documentPath" target="documentPath" />
          <zeebe:output source="=document" target="unstructuredLoanDocument" />
          <zeebe:output source="=documentStoredAt" target="unstructuredDocumentStoredAt" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_split_to_store_unstructured</bpmn:incoming>
      <bpmn:outgoing>flow_store_unstructured_to_extract_unstructured</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_print_unstructured" name="Print&#10;Unstructured Result">
      <bpmn:documentation>Logs idpExtractionResultUnstructured + extractedDataResponseUnstructured via
PrintExtractionResultWorker.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.print-extraction-result" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Unstructured PDF Extract&#34;" target="templateLabel" />
          <zeebe:input source="=idpExtractionResultUnstructured" target="extractionResult" />
          <zeebe:input source="=extractedDataResponseUnstructured" target="extractedData" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_02dg5sq</bpmn:incoming>
      <bpmn:outgoing>flow_print_unstructured_to_gw_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_store_image" name="Store&#10;Image Doc">
      <bpmn:documentation>Uploads the file at unstructuredImageDocumentPath into Camunda's Document
Store. Output renamed to imageLoanDocument / imageDocumentStoredAt.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.store-document" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=documentPath" target="documentPath" />
          <zeebe:output source="=document" target="imageLoanDocument" />
          <zeebe:output source="=documentStoredAt" target="imageDocumentStoredAt" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_split_to_store_image</bpmn:incoming>
      <bpmn:outgoing>flow_store_image_to_extract_image</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_extract_image" name="Extract&#10;Image" zeebe:modelerTemplate="idp-unstructured-extraction-connector-580932b9-8d10-412f-a02d-15425238dc99" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:documentation>Same UNSTRUCTURED engine config as task_extract_unstructured — AWS Textract
already OCRs the rendered page images regardless of whether the PDF has embedded text,
so a scanned/image-only PDF needs no different engine config, only a different source
document + taxonomy. Taxonomy currently matches the "Unstructured PDF With Image Extract"
IDP project's 2 fields: loanAmount, interestRate (24HF IDP With Unstructured PDF With
Image Extract.json).

Job type io.camunda:idp-extraction-connector-template:1, resultVariable
idpExtractionResultImage, resultExpression -&gt; extractedDataResponseImage (loanAmount,
interestRate, confidence = non-null count / 2).</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:idp-extraction-connector-template:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=imageLoanDocument" target="input.document" />
          <zeebe:input source="= input.extractionType" target="input.extractionType" />
          <zeebe:input source="=[&#10;  {&#10;    &#34;prompt&#34;: &#34;Find the user name from the file&#34;,&#10;    &#34;name&#34;: &#34;userName&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;find the date of birth of user&#34;,&#10;    &#34;name&#34;: &#34;dateOfBirth&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;find the email of user&#34;,&#10;    &#34;name&#34;: &#34;email&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;if there is image of signature or a signature present then it should return true otherwise false&#34;,&#10;    &#34;name&#34;: &#34;isSignatureUploaded&#34;&#10;  }&#10;]" target="input.taxonomyItems" />
          <zeebe:input source="= input.includedFields" target="input.includedFields" />
          <zeebe:input source="= input.renameMappings" target="input.renameMappings" />
          <zeebe:input source="= input.delimiter" target="input.delimiter" />
          <zeebe:input source="={&#10;  &#34;modelId&#34;: &#34;meta.llama3-70b-instruct-v1:0&#34;&#10;}" target="input.converseData" />
          <zeebe:input source="aws" target="baseRequest.type" />
          <zeebe:input source="credentials" target="baseRequest.authentication.type" />
          <zeebe:input source="{{secrets.IDP_AWS_ACCESSKEY}}" target="baseRequest.authentication.accessKey" />
          <zeebe:input source="{{secrets.IDP_AWS_SECRETKEY}}" target="baseRequest.authentication.secretKey" />
          <zeebe:input source="{{secrets.IDP_AWS_BUCKET_NAME}}" target="baseRequest.s3BucketName" />
          <zeebe:input source="AWS_TEXTRACT" target="baseRequest.extractionEngineType" />
          <zeebe:input source="{{secrets.IDP_AWS_REGION}}" target="baseRequest.configuration.region" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="2" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connector.IdpExtractionOutBoundTemplate.v1" />
          <zeebe:header key="resultVariable" value="idpExtractionResultImage" />
          <zeebe:header key="resultExpression" value="={extractedDataResponseImage: response.extractedFields.loanAmount}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_store_image_to_extract_image</bpmn:incoming>
      <bpmn:outgoing>flow_extract_image_to_print_image</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_print_image" name="Print&#10;Image Result">
      <bpmn:documentation>Logs idpExtractionResultImage + extractedDataResponseImage via
PrintExtractionResultWorker.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="idp.print-extraction-result" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;Unstructured PDF With Image Extract&#34;" target="templateLabel" />
          <zeebe:input source="=idpExtractionResultImage" target="extractionResult" />
          <zeebe:input source="=extractedDataResponseImage" target="extractedData" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_extract_image_to_print_image</bpmn:incoming>
      <bpmn:outgoing>flow_print_image_to_gw_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_template_test_complete" name="Template&#10;Test Complete">
      <bpmn:incoming>flow_gw_join_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_gw_split" sourceRef="start_event_document_uploaded" targetRef="gw_parallel_split" />
    <bpmn:sequenceFlow id="flow_gw_split_to_store_structured" sourceRef="gw_parallel_split" targetRef="task_store_structured">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=exportType = 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_split_to_store_unstructured" sourceRef="gw_parallel_split" targetRef="task_store_unstructured">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=exportType = 1</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_gw_split_to_store_image" sourceRef="gw_parallel_split" targetRef="task_store_image" />
    <bpmn:sequenceFlow id="flow_store_structured_to_extract_structured" sourceRef="task_store_structured" targetRef="Activity_0wvd79i" />
    <bpmn:sequenceFlow id="flow_store_unstructured_to_extract_unstructured" sourceRef="task_store_unstructured" targetRef="Activity_1mydyaq" />
    <bpmn:sequenceFlow id="flow_store_image_to_extract_image" sourceRef="task_store_image" targetRef="task_extract_image" />
    <bpmn:sequenceFlow id="flow_extract_image_to_print_image" sourceRef="task_extract_image" targetRef="task_print_image" />
    <bpmn:sequenceFlow id="flow_print_structured_to_gw_join" sourceRef="task_print_structured" targetRef="gw_parallel_join" />
    <bpmn:sequenceFlow id="flow_print_unstructured_to_gw_join" sourceRef="task_print_unstructured" targetRef="gw_parallel_join" />
    <bpmn:sequenceFlow id="flow_print_image_to_gw_join" sourceRef="task_print_image" targetRef="gw_parallel_join" />
    <bpmn:sequenceFlow id="flow_gw_join_to_end" sourceRef="gw_parallel_join" targetRef="end_template_test_complete" />
    <bpmn:exclusiveGateway id="gw_parallel_split" name="Split" default="flow_gw_split_to_store_image">
      <bpmn:incoming>flow_start_to_gw_split</bpmn:incoming>
      <bpmn:outgoing>flow_gw_split_to_store_structured</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_split_to_store_unstructured</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_split_to_store_image</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gw_parallel_join" name="Join">
      <bpmn:incoming>flow_print_structured_to_gw_join</bpmn:incoming>
      <bpmn:incoming>flow_print_unstructured_to_gw_join</bpmn:incoming>
      <bpmn:incoming>flow_print_image_to_gw_join</bpmn:incoming>
      <bpmn:outgoing>flow_gw_join_to_end</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_0wvd79i" name="Extract&#10;Structured" zeebe:modelerTemplate="idp-structured-extraction-connector-7a95e311-f079-424d-9835-591eac24b6de" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:idp-extraction-connector-template:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=structuredLoanDocument" target="input.document" />
          <zeebe:input source="STRUCTURED" target="input.extractionType" />
          <zeebe:input source="= input.taxonomyItems" target="input.taxonomyItems" />
          <zeebe:input source="=[&#10;  &#34;Residential Address&#34;,&#10;  &#34;Profile Photo&#34;,&#10;  &#34;Membership ID&#34;,&#10;  &#34;Full Name&#34;,&#10;  &#34;Blood Group&#34;,&#10;  &#34;Gender&#34;,&#10;  &#34;Date of Birth&#34;,&#10;  &#34;Emergency Contact Name&#34;,&#10;  &#34;Emergency Contact Number&#34;,&#10;  &#34;Email Address&#34;,&#10;  &#34;Mobile Number&#34;&#10;]" target="input.includedFields" />
          <zeebe:input source="={ }" target="input.renameMappings" />
          <zeebe:input source="= input.delimiter" target="input.delimiter" />
          <zeebe:input source="= input.converseData" target="input.converseData" />
          <zeebe:input source="aws" target="baseRequest.type" />
          <zeebe:input source="credentials" target="baseRequest.authentication.type" />
          <zeebe:input source="{{secrets.IDP_AWS_ACCESSKEY}}" target="baseRequest.authentication.accessKey" />
          <zeebe:input source="{{secrets.IDP_AWS_SECRETKEY}}" target="baseRequest.authentication.secretKey" />
          <zeebe:input source="{{secrets.IDP_AWS_BUCKET_NAME}}" target="baseRequest.s3BucketName" />
          <zeebe:input source="AWS_TEXTRACT" target="baseRequest.extractionEngineType" />
          <zeebe:input source="{{secrets.IDP_AWS_REGION}}" target="baseRequest.configuration.region" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="2" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connector.IdpExtractionOutBoundTemplate.v1" />
          <zeebe:header key="resultVariable" value="idpExtractionResultStructured" />
          <zeebe:header key="resultExpression" value="={extractedDataResponseStructured: response.extractedFields}" />
          <zeebe:header key="errorExpression" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_store_structured_to_extract_structured</bpmn:incoming>
      <bpmn:outgoing>Flow_0lrpjgc</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0lrpjgc" sourceRef="Activity_0wvd79i" targetRef="task_print_structured" />
    <bpmn:serviceTask id="Activity_1mydyaq" name="Extract&#10;Unstructured" zeebe:modelerTemplate="idp-unstructured-extraction-connector-d55fac82-25da-4bd1-8005-93fb7da0c21e" zeebe:modelerTemplateVersion="3" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:idp-extraction-connector-template:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="=unstructuredLoanDocument" target="input.document" />
          <zeebe:input source="= input.extractionType" target="input.extractionType" />
          <zeebe:input source="=[&#10;  {&#10;    &#34;prompt&#34;: &#34;if there is image of signature or a signature present then it should return true otherwise false&#34;,&#10;    &#34;name&#34;: &#34;isSignedUploaded&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;find the date of birth of user&#34;,&#10;    &#34;name&#34;: &#34;birthDate&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;find the email of user&#34;,&#10;    &#34;name&#34;: &#34;email&#34;&#10;  },&#10;  {&#10;    &#34;prompt&#34;: &#34;find the mobile number of user&#34;,&#10;    &#34;name&#34;: &#34;mobileNumber&#34;&#10;  }&#10;]" target="input.taxonomyItems" />
          <zeebe:input source="= input.includedFields" target="input.includedFields" />
          <zeebe:input source="= input.renameMappings" target="input.renameMappings" />
          <zeebe:input source="= input.delimiter" target="input.delimiter" />
          <zeebe:input source="={&#10;  &#34;modelId&#34;: &#34;meta.llama3-70b-instruct-v1:0&#34;&#10;}" target="input.converseData" />
          <zeebe:input source="aws" target="baseRequest.type" />
          <zeebe:input source="credentials" target="baseRequest.authentication.type" />
          <zeebe:input source="{{secrets.IDP_AWS_ACCESSKEY}}" target="baseRequest.authentication.accessKey" />
          <zeebe:input source="{{secrets.IDP_AWS_SECRETKEY}}" target="baseRequest.authentication.secretKey" />
          <zeebe:input source="{{secrets.IDP_AWS_BUCKET_NAME}}" target="baseRequest.s3BucketName" />
          <zeebe:input source="AWS_TEXTRACT" target="baseRequest.extractionEngineType" />
          <zeebe:input source="{{secrets.IDP_AWS_REGION}}" target="baseRequest.configuration.region" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="2" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connector.IdpExtractionOutBoundTemplate.v1" />
          <zeebe:header key="resultVariable" value="idpExtractionResultUnstructured" />
          <zeebe:header key="resultExpression" value="={extractedDataResponseUnstructured: response.extractedFields}" />
          <zeebe:header key="errorExpression" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_store_unstructured_to_extract_unstructured</bpmn:incoming>
      <bpmn:outgoing>Flow_02dg5sq</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_02dg5sq" sourceRef="Activity_1mydyaq" targetRef="task_print_unstructured" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="loan-document-idp-process">
