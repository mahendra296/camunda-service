      <bpmndi:BPMNShape id="Shape_payment" bpmnElement="task_process_payment">
        <dc:Bounds x="930" y="240" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Payment error boundary (non-interrupting on right-bottom of task) -->
      <bpmndi:BPMNShape id="Shape_boundary_payment" bpmnElement="boundary_payment_error">
        <dc:Bounds x="952" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="990" y="326" width="44" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Payment error handling — bottom lane y=420 -->
      <bpmndi:BPMNShape id="Shape_handle_payment" bpmnElement="task_handle_payment_failure">
