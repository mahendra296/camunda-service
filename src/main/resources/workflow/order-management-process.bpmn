<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" id="Definitions_OrderManagement" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:message id="Message_OrderCancellation" name="OrderCancellation">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=orderId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_ShipmentReady" name="ShipmentReady">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=orderId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:message id="Message_DeliveryConfirmation" name="DeliveryConfirmation">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=orderId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:error id="Error_PaymentFailed" name="PaymentFailed" errorCode="PAYMENT_FAILED" />
  <bpmn:error id="Error_OrderRejected" name="OrderRejected" errorCode="ORDER_REJECTED" />
  <bpmn:process id="order-management-process" name="Order Management Process" isExecutable="true">
    <bpmn:startEvent id="start_event_order_received" name="Order&#10;Received">
      <bpmn:outgoing>flow_start_to_validate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_validate_order" name="Validate Order">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.validate" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_to_validate</bpmn:incoming>
      <bpmn:outgoing>flow_validate_to_gw_valid</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_order_valid" name="Order&#10;Valid?" default="flow_gw_valid_yes">
      <bpmn:incoming>flow_validate_to_gw_valid</bpmn:incoming>
      <bpmn:outgoing>flow_gw_valid_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_valid_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_send_rejection" name="Send Rejection&#10;Notification">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.send-rejection" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_valid_no</bpmn:incoming>
      <bpmn:outgoing>flow_rejection_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_order_rejected" name="Order&#10;Rejected">
      <bpmn:incoming>flow_rejection_to_end</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrDef_rejected" errorRef="Error_OrderRejected" />
    </bpmn:endEvent>
    <bpmn:serviceTask id="task_check_inventory" name="Check Inventory">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.check-inventory" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_valid_yes</bpmn:incoming>
      <bpmn:outgoing>flow_inventory_to_gw_stock</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_in_stock" name="In&#10;Stock?" default="flow_gw_stock_yes">
      <bpmn:incoming>flow_inventory_to_gw_stock</bpmn:incoming>
      <bpmn:outgoing>flow_gw_stock_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_stock_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_backorder" name="Notify Customer:&#10;Backorder">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.notify-backorder" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_stock_no</bpmn:incoming>
      <bpmn:outgoing>flow_backorder_to_timer</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="timer_wait_restock" name="Wait 24h&#10;for Restock">
      <bpmn:incoming>flow_backorder_to_timer</bpmn:incoming>
      <bpmn:timerEventDefinition id="TimerDef_restock">
        <bpmn:timeDuration>PT1M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_reserve_inventory" name="Reserve Inventory">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.reserve-inventory" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_stock_yes</bpmn:incoming>
      <bpmn:outgoing>flow_reserve_to_payment</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_process_payment" name="Process Payment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.process-payment" retries="1" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_reserve_to_payment</bpmn:incoming>
      <bpmn:outgoing>flow_payment_to_gw_result</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="boundary_payment_error" name="Payment&#10;Error" attachedToRef="task_process_payment">
      <bpmn:outgoing>flow_payment_error_to_handle</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrDef_payment_boundary" errorRef="Error_PaymentFailed" />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_handle_payment_failure" name="Handle Payment&#10;Failure">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.handle-payment-failure" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_payment_error_to_handle</bpmn:incoming>
      <bpmn:outgoing>flow_handle_payment_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_payment_error" name="Payment&#10;Error End">
      <bpmn:incoming>flow_handle_payment_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="gw_payment_result" name="Payment&#10;Successful?" default="flow_payment_success">
      <bpmn:incoming>flow_payment_to_gw_result</bpmn:incoming>
      <bpmn:outgoing>flow_payment_success</bpmn:outgoing>
      <bpmn:outgoing>flow_payment_declined</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_notify_payment_failed" name="Notify Payment&#10;Declined">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.notify-payment-failed" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_payment_declined</bpmn:incoming>
      <bpmn:outgoing>flow_notify_payment_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_payment_declined" name="Order Payment&#10;Declined">
      <bpmn:incoming>flow_notify_payment_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:parallelGateway id="gw_parallel_split" name="Parallel&#10;Split">
      <bpmn:incoming>flow_payment_success</bpmn:incoming>
      <bpmn:outgoing>flow_parallel_to_shipment</bpmn:outgoing>
      <bpmn:outgoing>flow_parallel_to_confirmation</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="task_prepare_shipment" name="Prepare Shipment">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.prepare-shipment" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_parallel_to_shipment</bpmn:incoming>
      <bpmn:outgoing>flow_shipment_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_send_confirmation" name="Send Order&#10;Confirmation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.send-confirmation" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_parallel_to_confirmation</bpmn:incoming>
      <bpmn:outgoing>flow_confirmation_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="gw_parallel_join" name="Join">
      <bpmn:incoming>flow_shipment_to_join</bpmn:incoming>
      <bpmn:incoming>flow_confirmation_to_join</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_event_gw</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:eventBasedGateway id="gw_event_based" name="Await Event">
      <bpmn:incoming>flow_join_to_event_gw</bpmn:incoming>
      <bpmn:outgoing>flow_event_gw_to_cancel</bpmn:outgoing>
      <bpmn:outgoing>flow_event_gw_to_sla</bpmn:outgoing>
      <bpmn:outgoing>flow_event_gw_to_shipment_ready</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="catch_cancellation" name="Customer&#10;Cancels Order">
      <bpmn:incoming>flow_event_gw_to_cancel</bpmn:incoming>
      <bpmn:outgoing>flow_cancel_to_process</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_cancel" messageRef="Message_OrderCancellation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_process_cancellation" name="Process Cancellation&#10;&#38; Refund">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.process-cancellation" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_cancel_to_process</bpmn:incoming>
      <bpmn:outgoing>flow_cancellation_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_order_cancelled" name="Order&#10;Cancelled">
      <bpmn:incoming>flow_cancellation_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="catch_sla_breach" name="SLA Breach&#10;(48h)">
      <bpmn:incoming>flow_event_gw_to_sla</bpmn:incoming>
      <bpmn:outgoing>flow_sla_to_escalate</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_sla">
        <bpmn:timeDuration>PT48H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="task_escalate_manager" name="Escalate to&#10;Manager">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="manager" />
        <zeebe:formDefinition formKey="escalation-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_sla_to_escalate</bpmn:incoming>
      <bpmn:outgoing>flow_escalate_to_merge</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="catch_shipment_ready" name="Shipment&#10;Ready">
      <bpmn:incoming>flow_event_gw_to_shipment_ready</bpmn:incoming>
      <bpmn:outgoing>flow_shipment_ready_to_merge</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_shipment_ready" messageRef="Message_ShipmentReady" />
    </bpmn:intermediateCatchEvent>
    <bpmn:inclusiveGateway id="gw_pre_ship_merge" name="Merge to&#10;Shipping">
      <bpmn:incoming>flow_escalate_to_merge</bpmn:incoming>
      <bpmn:incoming>flow_shipment_ready_to_merge</bpmn:incoming>
      <bpmn:outgoing>flow_merge_to_ship</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:subProcess id="subprocess_shipment" name="Shipment Process&#10;(Per Product)">
      <bpmn:incoming>flow_merge_to_ship</bpmn:incoming>
      <bpmn:outgoing>flow_ship_to_delivery</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="false">
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics
            inputCollection="=items"
            inputElement="currentItem"
            outputCollection="shipments"
            outputElement="=shipmentResult" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
      <bpmn:startEvent id="ship_start" name="Shipment&#10;Started">
        <bpmn:outgoing>flow_ship_start_to_assign</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="task_assign_carrier" name="Assign Carrier">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="shipment.assign-carrier" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flow_ship_start_to_assign</bpmn:incoming>
        <bpmn:outgoing>flow_assign_to_label</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="task_generate_label" name="Generate&#10;Shipping Label">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="shipment.generate-label" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flow_assign_to_label</bpmn:incoming>
        <bpmn:outgoing>flow_label_to_pick</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="task_pick_pack" name="Pick &amp; Pack&#10;Items">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="shipment.pick-pack" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flow_label_to_pick</bpmn:incoming>
        <bpmn:outgoing>flow_pick_to_dispatch</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="task_dispatch_carrier" name="Dispatch to&#10;Carrier">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="shipment.dispatch" retries="3" />
        </bpmn:extensionElements>
        <bpmn:incoming>flow_pick_to_dispatch</bpmn:incoming>
        <bpmn:outgoing>flow_dispatch_to_end</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="ship_end" name="Shipment&#10;Dispatched">
        <bpmn:incoming>flow_dispatch_to_end</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="flow_ship_start_to_assign" sourceRef="ship_start" targetRef="task_assign_carrier" />
      <bpmn:sequenceFlow id="flow_assign_to_label" sourceRef="task_assign_carrier" targetRef="task_generate_label" />
      <bpmn:sequenceFlow id="flow_label_to_pick" sourceRef="task_generate_label" targetRef="task_pick_pack" />
      <bpmn:sequenceFlow id="flow_pick_to_dispatch" sourceRef="task_pick_pack" targetRef="task_dispatch_carrier" />
      <bpmn:sequenceFlow id="flow_dispatch_to_end" sourceRef="task_dispatch_carrier" targetRef="ship_end" />
    </bpmn:subProcess>
    <bpmn:boundaryEvent id="boundary_shipping_sla" name="Shipping SLA&#10;(72h)" cancelActivity="false" attachedToRef="subprocess_shipment">
      <bpmn:outgoing>flow_shipping_sla_to_handle</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_shipping_sla">
        <bpmn:timeDuration>PT72H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="task_handle_sla_breach" name="Handle Shipping&#10;SLA Breach">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.handle-sla-breach" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_shipping_sla_to_handle</bpmn:incoming>
      <bpmn:outgoing>flow_sla_breach_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_sla_notified" name="SLA Escalation&#10;Notified">
      <bpmn:incoming>flow_sla_breach_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateCatchEvent id="catch_delivery_confirmation" name="Delivery&#10;Confirmed">
      <bpmn:incoming>flow_ship_to_delivery</bpmn:incoming>
      <bpmn:outgoing>flow_delivery_to_gw</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_delivery" messageRef="Message_DeliveryConfirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="gw_delivery_result" name="Delivered&#10;Successfully?" default="flow_delivery_yes">
      <bpmn:incoming>flow_delivery_to_gw</bpmn:incoming>
      <bpmn:outgoing>flow_delivery_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_delivery_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_send_delivery_confirmation" name="Send Delivery&#10;Confirmation">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.send-delivery-confirmation" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_delivery_yes</bpmn:incoming>
      <bpmn:outgoing>flow_delivery_confirmation_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_order_complete" name="Order Completed&#10;Successfully">
      <bpmn:incoming>flow_delivery_confirmation_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="task_handle_delivery_issue" name="Handle Delivery&#10;Issue">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="support-agent" />
        <zeebe:formDefinition formKey="delivery-issue-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_delivery_no</bpmn:incoming>
      <bpmn:outgoing>flow_issue_to_gw_reship</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_reship_or_refund" name="Reship or&#10;Refund?" default="flow_gw_reship">
      <bpmn:incoming>flow_issue_to_gw_reship</bpmn:incoming>
      <bpmn:outgoing>flow_gw_reship</bpmn:outgoing>
      <bpmn:outgoing>flow_gw_refund</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_reship_order" name="Reship Order">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.reship" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_reship</bpmn:incoming>
      <bpmn:outgoing>flow_reship_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_process_refund" name="Process Refund">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="order.process-refund" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gw_refund</bpmn:incoming>
      <bpmn:outgoing>flow_refund_to_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_reshipped" name="Order&#10;Reshipped">
      <bpmn:incoming>flow_reship_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_refunded" name="Order&#10;Refunded">
      <bpmn:incoming>flow_refund_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_to_validate" sourceRef="start_event_order_received" targetRef="task_validate_order" />
    <bpmn:sequenceFlow id="flow_validate_to_gw_valid" sourceRef="task_validate_order" targetRef="gw_order_valid" />
    <bpmn:sequenceFlow id="flow_gw_valid_yes" name="Valid" sourceRef="gw_order_valid" targetRef="task_check_inventory" />
    <bpmn:sequenceFlow id="flow_gw_valid_no" name="Invalid" sourceRef="gw_order_valid" targetRef="task_send_rejection">
      <bpmn:conditionExpression>= orderValid = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_rejection_to_end" sourceRef="task_send_rejection" targetRef="end_order_rejected" />
    <bpmn:sequenceFlow id="flow_inventory_to_gw_stock" sourceRef="task_check_inventory" targetRef="gw_in_stock" />
    <bpmn:sequenceFlow id="flow_gw_stock_yes" name="In Stock" sourceRef="gw_in_stock" targetRef="task_reserve_inventory" />
    <bpmn:sequenceFlow id="flow_gw_stock_no" name="Out of Stock" sourceRef="gw_in_stock" targetRef="task_notify_backorder">
      <bpmn:conditionExpression>= inStock = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_backorder_to_timer" sourceRef="task_notify_backorder" targetRef="timer_wait_restock" />
    <bpmn:sequenceFlow id="flow_reserve_to_payment" sourceRef="task_reserve_inventory" targetRef="task_process_payment" />
    <bpmn:sequenceFlow id="flow_payment_to_gw_result" sourceRef="task_process_payment" targetRef="gw_payment_result" />
    <bpmn:sequenceFlow id="flow_payment_error_to_handle" sourceRef="boundary_payment_error" targetRef="task_handle_payment_failure" />
    <bpmn:sequenceFlow id="flow_handle_payment_to_end" sourceRef="task_handle_payment_failure" targetRef="end_payment_error" />
    <bpmn:sequenceFlow id="flow_payment_success" name="Success" sourceRef="gw_payment_result" targetRef="gw_parallel_split" />
    <bpmn:sequenceFlow id="flow_payment_declined" name="Declined" sourceRef="gw_payment_result" targetRef="task_notify_payment_failed">
      <bpmn:conditionExpression>= paymentStatus = "DECLINED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_notify_payment_to_end" sourceRef="task_notify_payment_failed" targetRef="end_payment_declined" />
    <bpmn:sequenceFlow id="flow_parallel_to_shipment" sourceRef="gw_parallel_split" targetRef="task_prepare_shipment" />
    <bpmn:sequenceFlow id="flow_parallel_to_confirmation" sourceRef="gw_parallel_split" targetRef="task_send_confirmation" />
    <bpmn:sequenceFlow id="flow_shipment_to_join" sourceRef="task_prepare_shipment" targetRef="gw_parallel_join" />
    <bpmn:sequenceFlow id="flow_confirmation_to_join" sourceRef="task_send_confirmation" targetRef="gw_parallel_join" />
    <bpmn:sequenceFlow id="flow_join_to_event_gw" sourceRef="gw_parallel_join" targetRef="gw_event_based" />
    <bpmn:sequenceFlow id="flow_event_gw_to_cancel" sourceRef="gw_event_based" targetRef="catch_cancellation" />
    <bpmn:sequenceFlow id="flow_event_gw_to_sla" sourceRef="gw_event_based" targetRef="catch_sla_breach" />
    <bpmn:sequenceFlow id="flow_event_gw_to_shipment_ready" sourceRef="gw_event_based" targetRef="catch_shipment_ready" />
    <bpmn:sequenceFlow id="flow_cancel_to_process" sourceRef="catch_cancellation" targetRef="task_process_cancellation" />
    <bpmn:sequenceFlow id="flow_cancellation_to_end" sourceRef="task_process_cancellation" targetRef="end_order_cancelled" />
    <bpmn:sequenceFlow id="flow_sla_to_escalate" sourceRef="catch_sla_breach" targetRef="task_escalate_manager" />
    <bpmn:sequenceFlow id="flow_escalate_to_merge" sourceRef="task_escalate_manager" targetRef="gw_pre_ship_merge" />
    <bpmn:sequenceFlow id="flow_shipment_ready_to_merge" sourceRef="catch_shipment_ready" targetRef="gw_pre_ship_merge" />
    <bpmn:sequenceFlow id="flow_merge_to_ship" sourceRef="gw_pre_ship_merge" targetRef="subprocess_shipment" />
    <bpmn:sequenceFlow id="flow_ship_to_delivery" sourceRef="subprocess_shipment" targetRef="catch_delivery_confirmation" />
    <bpmn:sequenceFlow id="flow_shipping_sla_to_handle" sourceRef="boundary_shipping_sla" targetRef="task_handle_sla_breach" />
    <bpmn:sequenceFlow id="flow_sla_breach_to_end" sourceRef="task_handle_sla_breach" targetRef="end_sla_notified" />
    <bpmn:sequenceFlow id="flow_delivery_to_gw" sourceRef="catch_delivery_confirmation" targetRef="gw_delivery_result" />
    <bpmn:sequenceFlow id="flow_delivery_yes" name="Delivered" sourceRef="gw_delivery_result" targetRef="task_send_delivery_confirmation" />
    <bpmn:sequenceFlow id="flow_delivery_no" name="Not Delivered" sourceRef="gw_delivery_result" targetRef="task_handle_delivery_issue">
      <bpmn:conditionExpression>= deliverySuccess = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_delivery_confirmation_to_end" sourceRef="task_send_delivery_confirmation" targetRef="end_order_complete" />
    <bpmn:sequenceFlow id="flow_issue_to_gw_reship" sourceRef="task_handle_delivery_issue" targetRef="gw_reship_or_refund" />
    <bpmn:sequenceFlow id="flow_gw_reship" name="Reship" sourceRef="gw_reship_or_refund" targetRef="task_reship_order" />
    <bpmn:sequenceFlow id="flow_gw_refund" name="Refund" sourceRef="gw_reship_or_refund" targetRef="task_process_refund">
      <bpmn:conditionExpression>= resolution = "REFUND"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_reship_to_end" sourceRef="task_reship_order" targetRef="end_reshipped" />
    <bpmn:sequenceFlow id="flow_refund_to_end" sourceRef="task_process_refund" targetRef="end_refunded" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="order-management-process">

      <!-- ══════════════════════════════════════════════════════
