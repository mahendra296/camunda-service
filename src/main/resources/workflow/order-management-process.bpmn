        <bpmndi:BPMNLabel>
          <dc:Bounds x="1163" y="258" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Payment declined → Notify Payment Failed (down to y=440) -->
      <bpmndi:BPMNEdge id="Edge_pay_declined" bpmnElement="flow_payment_declined">
        <di:waypoint x="1110" y="305" />
        <di:waypoint x="1110" y="458" />
        <di:waypoint x="1200" y="458" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1114" y="368" width="43" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_notify_pay_end" bpmnElement="flow_notify_payment_to_end">
        <di:waypoint x="1300" y="460" />
        <di:waypoint x="1360" y="460" />
      </bpmndi:BPMNEdge>

      <!-- ══════════════════════════════════════════════════════
           EDGES — SECTION 4: Parallel branches
           ══════════════════════════════════════════════════════ -->
      <!-- Parallel Split → Prepare Shipment (up) -->
      <bpmndi:BPMNEdge id="Edge_par_to_ship" bpmnElement="flow_parallel_to_shipment">
        <di:waypoint x="1260" y="255" />
        <di:waypoint x="1260" y="230" />
        <di:waypoint x="1360" y="230" />
      </bpmndi:BPMNEdge>

      <!-- Parallel Split → Send Confirmation (down) -->
      <bpmndi:BPMNEdge id="Edge_par_to_confirm" bpmnElement="flow_parallel_to_confirmation">
        <di:waypoint x="1260" y="305" />
        <di:waypoint x="1260" y="360" />
        <di:waypoint x="1360" y="360" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ship_join" bpmnElement="flow_shipment_to_join">
        <di:waypoint x="1460" y="230" />
        <di:waypoint x="1550" y="230" />
        <di:waypoint x="1550" y="255" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_confirm_join" bpmnElement="flow_confirmation_to_join">
        <di:waypoint x="1460" y="360" />
        <di:waypoint x="1550" y="360" />
        <di:waypoint x="1550" y="305" />
      </bpmndi:BPMNEdge>

      <!-- ══════════════════════════════════════════════════════
           EDGES — SECTION 5: Event-based gateway
           ══════════════════════════════════════════════════════ -->
      <bpmndi:BPMNEdge id="Edge_join_event" bpmnElement="flow_join_to_event_gw">
        <di:waypoint x="1575" y="280" />
        <di:waypoint x="1655" y="280" />
      </bpmndi:BPMNEdge>

      <!-- Event GW → Cancellation catch (up to y=120) -->
      <bpmndi:BPMNEdge id="Edge_evgw_cancel" bpmnElement="flow_event_gw_to_cancel">
        <di:waypoint x="1680" y="255" />
        <di:waypoint x="1680" y="120" />
        <di:waypoint x="1782" y="120" />
      </bpmndi:BPMNEdge>

      <!-- Event GW → SLA breach catch (down to y=458) -->
      <bpmndi:BPMNEdge id="Edge_evgw_sla" bpmnElement="flow_event_gw_to_sla">
        <di:waypoint x="1680" y="305" />
        <di:waypoint x="1680" y="458" />
        <di:waypoint x="1782" y="458" />
      </bpmndi:BPMNEdge>

      <!-- Event GW → Shipment Ready (straight) -->
      <bpmndi:BPMNEdge id="Edge_evgw_ship" bpmnElement="flow_event_gw_to_shipment_ready">
        <di:waypoint x="1705" y="280" />
        <di:waypoint x="1782" y="280" />
      </bpmndi:BPMNEdge>

      <!-- Cancellation path -->
      <bpmndi:BPMNEdge id="Edge_cancel_process" bpmnElement="flow_cancel_to_process">
        <di:waypoint x="1818" y="120" />
        <di:waypoint x="1880" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_cancel_end" bpmnElement="flow_cancellation_to_end">
        <di:waypoint x="1980" y="120" />
        <di:waypoint x="2042" y="120" />
      </bpmndi:BPMNEdge>

      <!-- SLA escalation path -->
      <bpmndi:BPMNEdge id="Edge_sla_escalate" bpmnElement="flow_sla_to_escalate">
        <di:waypoint x="1818" y="458" />
        <di:waypoint x="1880" y="458" />
      </bpmndi:BPMNEdge>

      <!-- Escalate → Pre-ship merge (up to y=305) -->
      <bpmndi:BPMNEdge id="Edge_escalate_merge" bpmnElement="flow_escalate_to_merge">
        <di:waypoint x="1980" y="458" />
        <di:waypoint x="2080" y="458" />
        <di:waypoint x="2080" y="305" />
      </bpmndi:BPMNEdge>

      <!-- Shipment Ready → Pre-ship merge (straight) -->
      <bpmndi:BPMNEdge id="Edge_shipready_merge" bpmnElement="flow_shipment_ready_to_merge">
        <di:waypoint x="1818" y="280" />
        <di:waypoint x="2055" y="280" />
      </bpmndi:BPMNEdge>

      <!-- ══════════════════════════════════════════════════════
           EDGES — SECTION 6: Into subprocess
           ══════════════════════════════════════════════════════ -->
      <!-- Merge GW → Subprocess left edge -->
      <bpmndi:BPMNEdge id="Edge_merge_ship" bpmnElement="flow_merge_to_ship">
        <di:waypoint x="2105" y="280" />
        <di:waypoint x="2170" y="280" />
      </bpmndi:BPMNEdge>

      <!-- ══════════════════════════════════════════════════════
           EDGES — SECTION 7: Shipment subprocess internals
           ══════════════════════════════════════════════════════ -->
      <bpmndi:BPMNEdge id="Edge_ship_start_assign" bpmnElement="flow_ship_start_to_assign">
        <di:waypoint x="2258" y="280" />
        <di:waypoint x="2310" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_assign_label" bpmnElement="flow_assign_to_label">
        <di:waypoint x="2410" y="280" />
        <di:waypoint x="2460" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_label_pick" bpmnElement="flow_label_to_pick">
        <di:waypoint x="2560" y="280" />
        <di:waypoint x="2610" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_pick_dispatch" bpmnElement="flow_pick_to_dispatch">
        <di:waypoint x="2710" y="280" />
        <di:waypoint x="2760" y="280" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_dispatch_end" bpmnElement="flow_dispatch_to_end">
        <di:waypoint x="2860" y="280" />
        <di:waypoint x="2912" y="280" />
      </bpmndi:BPMNEdge>

      <!-- Subprocess right edge → Delivery Confirmation catch -->
      <bpmndi:BPMNEdge id="Edge_ship_delivery" bpmnElement="flow_ship_to_delivery">
        <di:waypoint x="2970" y="280" />
        <di:waypoint x="3030" y="280" />
      </bpmndi:BPMNEdge>

      <!-- SLA boundary timer → Handle SLA breach (down) -->
      <bpmndi:BPMNEdge id="Edge_sla_boundary" bpmnElement="flow_shipping_sla_to_handle">
        <di:waypoint x="2220" y="403" />
        <di:waypoint x="2220" y="460" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_sla_end" bpmnElement="flow_sla_breach_to_end">
        <di:waypoint x="2270" y="500" />
        <di:waypoint x="2330" y="500" />
      </bpmndi:BPMNEdge>

      <!-- ══════════════════════════════════════════════════════
           EDGES — SECTION 8: Delivery & resolution
           ══════════════════════════════════════════════════════ -->
      <bpmndi:BPMNEdge id="Edge_delivery_gw" bpmnElement="flow_delivery_to_gw">
        <di:waypoint x="3066" y="280" />
        <di:waypoint x="3120" y="280" />
      </bpmndi:BPMNEdge>

      <!-- Delivered Successfully (up) -->
      <bpmndi:BPMNEdge id="Edge_delivery_yes" bpmnElement="flow_delivery_yes">
        <di:waypoint x="3145" y="255" />
        <di:waypoint x="3145" y="230" />
        <di:waypoint x="3230" y="230" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3153" y="233" width="47" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Not Delivered (down) -->
      <bpmndi:BPMNEdge id="Edge_delivery_no" bpmnElement="flow_delivery_no">
        <di:waypoint x="3145" y="305" />
        <di:waypoint x="3145" y="360" />
        <di:waypoint x="3230" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3148" y="323" width="67" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_confirm_delivery" bpmnElement="flow_delivery_confirmation_to_end">
        <di:waypoint x="3330" y="230" />
        <di:waypoint x="3390" y="230" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_issue_gw" bpmnElement="flow_issue_to_gw_reship">
        <di:waypoint x="3330" y="360" />
        <di:waypoint x="3390" y="360" />
      </bpmndi:BPMNEdge>

      <!-- Reship (up) -->
      <bpmndi:BPMNEdge id="Edge_gw_reship" bpmnElement="flow_gw_reship">
        <di:waypoint x="3440" y="360" />
        <di:waypoint x="3440" y="310" />
        <di:waypoint x="3500" y="310" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3443" y="323" width="35" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Refund (down) -->
      <bpmndi:BPMNEdge id="Edge_gw_refund" bpmnElement="flow_gw_refund">
        <di:waypoint x="3415" y="385" />
        <di:waypoint x="3415" y="440" />
        <di:waypoint x="3500" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="3418" y="403" width="36" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_reship_end" bpmnElement="flow_reship_to_end">
        <di:waypoint x="3600" y="310" />
        <di:waypoint x="3660" y="310" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_refund_end" bpmnElement="flow_refund_to_end">
        <di:waypoint x="3600" y="440" />
        <di:waypoint x="3660" y="440" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
